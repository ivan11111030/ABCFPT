# Example Environment Variables for Professional Streaming Setup

# OBS Studio WebSocket Configuration
OBS_HOST=localhost
OBS_PORT=4444
OBS_PASSWORD=

# Server Port
PORT=4000

# Socket Server URL (for production deployment)
SOCKET_SERVER_URL=http://localhost:4000

# Facebook Live / RTMP Configuration
# ⚠️ KEEP THESE SECRET - NEVER COMMIT TO GIT ⚠️
FACEBOOK_RTMP_URL=rtmp://live-api.facebook.com:80/rtmp/
FACEBOOK_STREAM_KEY=your_stream_key_here

# NDI Runtime (if using NDI cameras)
NDI_RUNTIME_PATH=/path/to/ndi/runtime

# Encoding Defaults
DEFAULT_ENCODING_PROFILE=medium
